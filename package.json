{
    "name": "minbin",
    "version": "0.1.2",
    "description": "a minimal, ephemeral pastebin service.",
    "type": "module",
    "main": "dist/server.js",
    "engines": {
        "node": ">=20"
    },
    "scripts": {
        "build": "tsc",
        "start": "node dist/server.js",
        "dev": "tsx watch src/server.ts",
        "typecheck": "tsc --noEmit",
        "test": "npm run build && node tests/integration.test.mjs && node tests/ratelimit.test.mjs"
    },
    "dependencies": {
        "@fastify/rate-limit": "^10.3.0",
        "@fastify/static": "^8.0.4",
        "@fastify/swagger": "^9.4.0",
        "animejs": "^4.4.1",
        "dotenv": "^17.4.2",
        "fastify": "^5.1.0",
        "hash-wasm": "^4.12.0",
        "ioredis": "^5.4.1",
        "nunjucks": "^3.2.4"
    },
    "devDependencies": {
        "@types/node": "^22.10.5",
        "@types/nunjucks": "^3.2.6",
        "ioredis-mock": "^8.9.0",
        "tsx": "^4.19.2",
        "typescript": "^5.7.2"
    }
}
