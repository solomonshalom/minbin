{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "buildCommand": "npm run build",
    "installCommand": "npm install --no-audit --no-fund",
    "rewrites": [
        { "source": "/(.*)", "destination": "/api/index" }
    ],
    "functions": {
        "api/index.js": {
            "memory": 256,
            "maxDuration": 10,
            "includeFiles": "{templates,dist}/**"
        }
    },
    "env": {
        "TRUST_PROXY": "true"
    },
    "build": {
        "env": {
            "TRUST_PROXY": "true"
        }
    }
}
